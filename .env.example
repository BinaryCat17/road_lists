# Yandex OAuth Credentials
# Получить можно тут: https://oauth.yandex.ru/client/new
# Callback URL должен быть: https://docs.salskayastep.ru/auth/yandex/callback
YANDEX_CLIENT_ID=your_client_id_here
YANDEX_CLIENT_SECRET=your_client_secret_here

# Base URL для callback
BASE_URL=https://docs.salskayastep.ru

# Порт (опционально, по умолчанию 3000)
PORT=3000
